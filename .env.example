# Example environment variables for ai-resume-builder
# Copy this file to .env.local (for local dev) or set equivalent vars in Vercel

# Database
DATABASE_URL="postgresql://user:password@host:5432/dbname"

# NextAuth (set to your deployed URL in production)
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="replace_with_a_secure_random_string"

# Google OAuth
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OpenAI
OPENAI_API_KEY="sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# Resend (optional email provider)
RESEND_API_KEY="re_xxx"

# Public client config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ResumeAI"
# Database
DATABASE_URL="postgresql://diwakar@localhost:5432/ai_resume_builder"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-this-in-production"

# OAuth Providers
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# OpenAI
OPENAI_API_KEY="your-openai-api-key"

# Resend (email)
RESEND_API_KEY="your-resend-api-key"

# UploadThing
UPLOADTHING_SECRET="your-uploadthing-secret"
UPLOADTHING_APP_ID="your-uploadthing-app-id"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ResumeAI"
